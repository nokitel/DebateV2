{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "title": { "type": "string" },
    "content": { "type": "string" },
    "strongest_pro": { "$ref": "#/$defs/argument" },
    "strongest_con": { "$ref": "#/$defs/argument" }
  },
  "required": ["title", "content", "strongest_pro", "strongest_con"],
  "$defs": {
    "argument": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "pro": { "$ref": "#/$defs/card" },
        "con": { "$ref": "#/$defs/card" }
      },
      "required": ["title", "content", "pro", "con"]
    },
    "card": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" }
      },
      "required": ["title", "content"]
    }
  }
}
