{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "lib/**/*.ts",
    "lib/**/*.tsx",
    ".next-dev-smoke/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    ".next/**",
    ".next-dev",
    ".next-dev/**"
  ]
}
