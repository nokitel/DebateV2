{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "agents": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "lens": { "type": "string" },
          "domain": { "type": "string" },
          "default_prompt": { "type": "string" },
          "skill_names": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "required": ["name", "description", "lens", "domain", "default_prompt", "skill_names"]
      }
    },
    "skills": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string", "enum": ["prompt"] },
          "description": { "type": "string" },
          "body": { "type": "string" },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "required": ["name", "type", "description", "body", "tags"]
      }
    }
  },
  "required": ["agents", "skills"]
}
